{
  "mcpServers": {
    "arxiv-mcp-server": {
      "args": [
        "arxiv-mcp-server"
      ],
      "command": "uvx",
      "env": {},
      "type": "stdio"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "command": "npx"
    },
    "deepwiki": {
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "command": "npx"
    },
    "youtube": {
      "args": [
        "@anaisbetts/mcp-youtube"
      ],
      "command": "npx",
      "env": {},
      "type": "stdio"
    }
  },
  "selectedAuthType": "oauth-personal"
}