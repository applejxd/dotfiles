{{ if .chezmoi.os "windows" }}
# Unix 系 OS のみで導入
.config/shell/*
.config/shell/gdb/*
.config/fish/*
.tmuxp/*
.bash_profile
.bashrc
.gdbinit
.profile
.tmux.conf
.Xmodmap
.xsessionrc
.zshenv
.zshrc
{{- end }}

{{- if ne .chezmoi.os "linux" }}
# Linux のみで導入
.chezmoiscripts/010_linux/*

{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# WSL で除外
.chezmoiscripts/010_linux/011_microsoft.sh
.chezmoiscripts/vscode_extensions.sh
{{-   else }}
# WSL のみで導入
.chezmoiscripts/010_linux/012_wsl.sh
.config/shell/wslenv.sh
{{-   end }}

{{- end }}

{{- if ne .chezmoi.os "darwin" }}
# Mac OS X のみで導入
.chezmoiscripts/020_mac/*

.config/shell/osxenv.sh
.config/shell/osxrc.sh
.mackup.cfg
{{- end }}

{{- if ne .chezmoi.username "applejxd" }}
# 個人 PC のみで導入
.chezmoiscripts/021_nodejs.sh
.chezmoiscripts/fetch_spacemacs.sh
.claude.json

.config/chezmoi/key.txt
{{- end }}

#{{- if not (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) }}
# needs key.txt to decrypt (need to run apply twice)
#{{- end }}

# 以下は一度のみコピー・復号

{{- if (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) }}
.config/chezmoi/key.txt
{{- end }}

{{- if (stat (joinPath .chezmoi.homeDir ".gitconfig")) }}
.gitconfig
