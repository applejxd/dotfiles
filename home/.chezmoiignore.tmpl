{{ if ne .chezmoi.os "windows" }}
# Unix の場合の除外
.chezmoiscripts/300_windows/*

{{-   if ne .chezmoi.os "linux" }}
# Linux のみの導入
.chezmoiscripts/100_linux/*

{{-   else }}

{{-     if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# WSL 以外で導入
.chezmoiscripts/100_linux/110_native/*
{{-     else }}
# WSL のみで導入
.chezmoiscripts/100_linux/190_wsl.sh

.config/shell/wslenv.sh
{{-     end }}

{{-   end }}

{{-   if ne .chezmoi.os "darwin" }}
# Mac OS X のみで導入
.chezmoiscripts/200_mac/*

.config/shell/osxenv.sh
.config/shell/osxrc.sh
.mackup.cfg
{{-   end }}

{{- else }}
# Unix 系 OS のみで導入
.chezmoiscripts/000_unix/*

.config/shell/*
.config/shell/gdb/*
.config/fish/*
.tmuxp/*
.bash_profile
.bashrc
.gdbinit
.profile
.tmux.conf
.Xmodmap
.xsessionrc
.zshenv
.zshrc

{{- end }}

{{- if ne .chezmoi.username "applejxd" }}
# 個人 PC のみで導入
.config/chezmoi/key.txt
{{- end }}

#{{- if not (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) }}
# needs key.txt to decrypt (need to run apply twice)
#{{- end }}

# 以下は一度のみコピー・復号

{{- if (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) }}
.config/chezmoi/key.txt
{{- end }}

{{- if (stat (joinPath .chezmoi.homeDir ".gitconfig")) }}
.gitconfig
{{- end }}
