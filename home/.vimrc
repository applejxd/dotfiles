" unable BG color for transparet BG
autocmd ColorScheme * highlight Normal ctermbg=None
autocmd ColorScheme * highlight LineNr ctermbg=None
autocmd ColorScheme * highlight EndOfBuffer ctermbg=None

" iceberg theme
colorscheme iceberg

" syntax highlight
syntax on 
" line number
set number
" auto-indent
set autoindent

" matching ()
set showmatch
" matching focus time
set matchtime=1
