# see below for documentation
# https://mise.jdx.dev/configuration.html

[tools]
usage = "latest" # for mise completion

# CLI
fzf = "0.53.0"  # to prevent bug
ghq = "latest"
bat = "latest"
eza = "latest"
jj ="latest"
ripgrep = "latest"
"aqua:dylanaraps/neofetch" = "latest"

# TUI
btop = "latest"
"pipx:nvitop" = "latest"
ctop = "latest"
tmux = "latest"
"pipx:tmuxp" = "latest"
"aqua:neovim/neovim" = "latest" # unstable for vfox
lazygit = "v0.59.0" # to use correct tag
yazi = "latest"

# dev
shellcheck = "latest"
hadolint = "latest"
python = "latest"
uv = "latest"
node = "latest"
deno = "latest"
"npm:@openai/codex" = "latest"

# backends (keep the latest for building tools)
rust = "latest"
go = "latest"

# others
chezmoi = "latest"

# see https://mise.jdx.dev/dev-tools/backends/go.html
"go:github.com/d-kuro/gwq/cmd/gwq" = "latest"

# see https://mise.jdx.dev/dev-tools/backends/cargo.html
"aqua:bvaisvil/zenith" = "latest"

{{- if eq .chezmoi.username "applejxd" }}
"npm:@google/gemini-cli" = "latest"
yt-dlp = "latest"
{{- end }}

[settings]
# for Tkinter (prebuild binaries doesn't contain GUI modules)
# see https://www.python.jp/install/ubuntu/index.html
python_compile = true
# for task runner
experimental = true
