{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "tools": {
    "allowed": [
      "glob",
      "google_web_search",
      "list_directory",
      "grep_search",
      "web_fetch"
    ],
    "exclude": [
      "run_shell_command(rm)",
      "run_shell_command(pip install)",
      "run_shell_command(python -m pip install)"
    ]
  },
  "mcpServers": {
    "arxiv-mcp-server": {
      "args": [
        "arxiv-mcp-server"
      ],
      "command": "uvx",
      "env": {},
      "type": "stdio"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "command": "npx"
    },
    "deepwiki": {
      "httpUrl": "https://mcp.deepwiki.com/mcp"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "command": "npx"
    },
    "youtube": {
      "args": [
        "@anaisbetts/mcp-youtube"
      ],
      "command": "npx",
      "env": {},
      "type": "stdio"
    }
  }
}