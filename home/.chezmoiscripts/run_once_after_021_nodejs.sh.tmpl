#!/usr/bin/env bash

set -euo pipefail

echo "Node.js と nvm をインストール/更新します..."
 
 
{{- if eq .chezmoi.os "linux" }}
# 依存
command -v curl >/dev/null 2>&1 || { sudo apt-get update -y && sudo apt-get install -y curl ca-certificates; }
{{- end }}

# nvm 導入（未導入時のみ）
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] || curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash

# nvm を読み込み→LTS導入/更新→LTSを有効化（PATH反映）
set +u
. "$NVM_DIR/nvm.sh"
set -u
if [ "$(nvm current 2>/dev/null || true)" != "none" ]; then
  nvm install --lts --reinstall-packages-from=current >/dev/null
else
  nvm install --lts >/dev/null
fi
nvm alias default 'lts/*' >/dev/null
nvm use --silent default

# 確認
echo "Node.js: $(node -v)"
echo "npm: $(npm -v)"
echo "nvm current: $(nvm current)"

{{- if eq .chezmoi.username "applejxd" }}
# AI ツール
npm install -g @anthropic-ai/claude-code
npm install -g @google/gemini-cli
npm install -g @openai/codex

# MCP サーバ
claude mcp add sequential-thinking -s user -- npx -y @modelcontextprotocol/server-sequential-thinking
claude mcp add -s user --transport sse deepwiki https://mcp.deepwiki.com/sse
claude mcp add context7 -s user -- npx -y @upstash/context7-mcp@latest
claude mcp add playwright -s user -- npx @playwright/mcp@latest
claude mcp add fetch -s user -- uvx mcp-server-fetch
# claude mcp add arxiv-mcp-server -s user -- uvx arxiv-mcp-server
# claude mcp add youtube -s user -- npx @anaisbetts/mcp-youtube
# claude mcp add yt-dlp -s user -- npx -y @kevinwatt/yt-dlp-mcp
{{- end }}

echo "✅ 完了：Node.js と nvm をインストール/更新しました"