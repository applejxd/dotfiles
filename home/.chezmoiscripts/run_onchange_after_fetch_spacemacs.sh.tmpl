{{- $tag := (gitHubLatestTag "syl20bnr/spacemacs").Name -}}
#!/bin/sh

set -eu

EMACS_D="${HOME}/.emacs.d"
TAG="{{ $tag }}"
STAMP="${HOME}/.cache/chezmoi-spacemacs-tag"

mkdir -p "$(dirname "$STAMP")"

if [ -f "$STAMP" ] && [ "$(cat "$STAMP")" = "$TAG" ] && [ -d "$EMACS_D" ]; then
  exit 0
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

archive_url="https://github.com/syl20bnr/spacemacs/archive/refs/tags/${TAG}.tar.gz"
curl -L "$archive_url" -o "$tmpdir/spacemacs.tar.gz"
mkdir -p "$tmpdir/unpack"
tar -xzf "$tmpdir/spacemacs.tar.gz" -C "$tmpdir/unpack"
src_dir="$(find "$tmpdir/unpack" -maxdepth 1 -mindepth 1 -type d | head -n1)"

rm -rf "${EMACS_D}.new"
cp -a "$src_dir" "${EMACS_D}.new"
rm -rf "$EMACS_D"
mv "${EMACS_D}.new" "$EMACS_D"

printf '%s' "$TAG" > "$STAMP"
