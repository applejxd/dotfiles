#!/bin/bash

set -euo pipefail

# VSCode
# see https://code.visualstudio.com/docs/setup/linux
if ! (type "code" >/dev/null 2>&1); then
    echo "Installing Visual Studio Code..." >&2

    sudo -v
    # Validate password by testing sudo access
    if ! echo "$password" | sudo -S true 2>/dev/null; then
        echo "ERROR: Invalid sudo password" >&2
        exit 1
    fi

    sudo apt-get install -y wget gpg
    wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > /tmp/microsoft.gpg
    sudo install -D -o root -g root -m 644 /tmp/microsoft.gpg /usr/share/keyrings/microsoft.gpg
    rm -f /tmp/microsoft.gpg

    sudo -S apt-get install -y apt-transport-https
    sudo -S apt update && sudo apt-get install -y code
fi
