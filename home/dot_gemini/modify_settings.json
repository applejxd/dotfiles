{{- /* chezmoi:modify-template */ -}}
{{- /* merge (Sprig) はネストされた辞書を再帰的にマージするため、mcpServers 等の辞書はそのまま統合される */ -}}
{{- $current := dict -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $current = fromJson .chezmoi.stdin -}}
{{- end -}}
{{- $managed := dict
    "general" (dict
        "sessionRetention" (dict
            "enabled" true
            "maxAge" "30d"
            "warningAcknowledged" true
        )
    )
    "security" (dict
        "auth" (dict
            "selectedType" "oauth-personal"
        )
    )
    "experimental" (dict
        "skills" (dict
            "enabled" true
        )
        "enableAgents" true
    )
    "mcpServers" (dict
        "deepwiki" (dict
            "httpUrl" "https://mcp.deepwiki.com/mcp"
        )
    )
-}}
{{- merge $managed $current | toPrettyJson -}}
