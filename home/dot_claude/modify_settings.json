{{- /* chezmoi:modify-template */ -}}
{{- /* permissions は dotfiles の値で完全上書き、env は dotfiles の値を優先してマージする */ -}}
{{- $current := dict -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $current = fromJson .chezmoi.stdin -}}
{{- end -}}
{{- $defaults := dict
    "includeCoAuthoredBy" false
-}}
{{- $allowList := list
    "Read(README.md)"
    "Bash(wc *)"
    "Bash(git diff *)"
    "Bash(git status *)"
    "Bash(git log *)"
    "Bash(git -C * diff *)"
    "Bash(git -C * log *)"
    "Bash(git -C * show *)"
    "Bash(grep -n *)"
    "Bash(find *)"
    "Read(pyproject.toml)"
    "Bash(uv pip list *)"
    "Bash(uv sync *)"
    "Bash(docker ps *)"
    "Bash(mise run *)"
    "WebFetch(domain:github.com)"
    "WebFetch(domain:hub.docker.com)"
    "WebFetch(domain:docs.docker.com)"
    "WebFetch(domain:raw.githubusercontent.com)"
    "WebFetch(domain:dev.to)"
    "WebFetch(domain:pypi.org)"
    "WebFetch(domain:docs.python.org)"
    "WebFetch(domain:packaging.python.org)"
    "WebFetch(domain:npmjs.com)"
    "WebFetch(domain:docs.npmjs.com)"
    "WebFetch(domain:registry.npmjs.org)"
    "WebFetch(domain:stackoverflow.com)"
    "WebFetch(domain:docs.github.com)"
    "WebFetch(domain:mise.jdx.dev)"
    "WebFetch(domain:docs.astral.sh)"
    "WebFetch(domain:chezmoi.io)"
    "WebFetch(domain:pre-commit.com)"
    "WebFetch(domain:docs.anthropic.com)"
    "WebFetch(domain:modelcontextprotocol.io)"
-}}
{{- $askList := list
    "Bash(uv add *)"
    "Bash(npm install *)"
    "Bash(npm ci *)"
    "Read(.env.*)"
    "Write(.env.*)"
    "Write(mise.toml)"
    "Bash(git commit *)"
    "Bash(python -c *)"
    "Bash(docker exec *)"
    "Bash(curl *)"
-}}
{{- $denyList := list
    "Bash(sudo *)"
    "Bash(rm *)"
    "Bash(git push *)"
    "Bash(git reset *)"
    "Bash(git rebase *)"
    "Bash(git config *)"
    "Read(**/.ssh/*)"
    "Read(**/id_rsa*)"
    "Read(**/id_ed25519*)"
    "Read(**/*token*)"
    "Read(**/*key*)"
    "Read(**/*secret*)"
    "Read(**/*credential*)"
    "Read(**/*password*)"
    "Read(.env)"
    "Write(.env)"
    "Write(**/secrets/**)"
    "Write(**/*secret*)"
    "Write(**/*credential*)"
    "Write(**/.ssh/*)"
    "Bash(wget *)"
    "Bash(nc *)"
    "Bash(telnet *)"
    "Bash(ssh *)"
    "Bash(npm uninstall *)"
    "Bash(npm remove *)"
    "Bash(psql *)"
    "Bash(mysql *)"
    "Bash(mongod *)"
    "Bash(redis-cli *)"
    "Bash(pip *)"
    "Bash(docker rm *)"
    "Bash(docker rmi *)"
    "mcp__supabase__execute_sql"
-}}
{{- $envDefaults := dict
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS" "1"
-}}
{{- $currentEnv := default (dict) (get $current "env") -}}
{{- $hookCmd := printf "python %s/.claude/hooks/check_bash.py" .chezmoi.homeDir -}}
{{- $result := merge $defaults $current -}}
{{- $_ := set $result "permissions" (dict
    "allow" $allowList
    "ask"   $askList
    "deny"  $denyList
) -}}
{{- $_ := set $result "env" (merge $envDefaults $currentEnv) -}}
{{- $_ := set $result "hooks" (dict
    "PreToolUse" (list
        (dict
            "matcher" "Bash"
            "hooks" (list
                (dict "type" "command" "command" $hookCmd)
            )
        )
    )
) -}}
{{- $result | toPrettyJson -}}
