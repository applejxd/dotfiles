{{- /* chezmoi:modify-template */ -}}
{{- /* merge (Sprig) はリストを統合せず上書きするため、permissions 内のリストは個別に concat+uniq で統合する */ -}}
{{- $current := dict -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $current = fromJson .chezmoi.stdin -}}
{{- end -}}
{{- $managed := dict
    "includeCoAuthoredBy" false
-}}
{{- $managedAllow := list
    "Read(README.md)"
    "Bash(wc *)"
    "Bash(git diff:*)"
    "Bash(git status:*)"
    "Bash(git log:*)"
    "Bash(git -C * diff *)"
    "Bash(git -C * log *)"
    "Bash(git -C * show *)"
    "Bash(grep -n:*)"
    "Read(pyproject.toml)"
    "Bash(uv pip list:*)"
    "Bash(uv sync:*)"
    "Bash(docker ps:*)"
    "WebFetch(domain:github.com)"
    "WebFetch(domain:hub.docker.com)"
    "WebFetch(domain:docs.docker.com)"
    "WebFetch(domain:raw.githubusercontent.com)"
    "WebFetch(domain:dev.to)"
    "WebFetch(domain:pypi.org)"
-}}
{{- $managedAsk := list
    "Bash(uv add:*)"
    "Bash(npm install:*)"
    "Bash(npm ci:*)"
    "Read(.env.*)"
    "Write(.env.*)"
    "Bash(git commit:*)"
    "Bash(python -c:*)"
    "Bash(docker exec:*)"
    "Bash(curl:*)"
-}}
{{- $managedDeny := list
    "Bash(sudo:*)"
    "Bash(rm:*)"
    "Bash(git push:*)"
    "Bash(git reset:*)"
    "Bash(git rebase:*)"
    "Bash(git config:*)"
    "Read(**/.ssh/*)"
    "Read(**/id_rsa*)"
    "Read(**/id_ed25519*)"
    "Read(**/*token*)"
    "Read(**/*key*)"
    "Read(**/*secret*)"
    "Read(**/*credential*)"
    "Read(**/*password*)"
    "Read(.env)"
    "Write(.env)"
    "Write(**/secrets/**)"
    "Write(**/*secret*)"
    "Write(**/*credential*)"
    "Write(**/.ssh/*)"
    "Bash(wget:*)"
    "Bash(nc:*)"
    "Bash(telnet:*)"
    "Bash(ssh:*)"
    "Bash(npm uninstall:*)"
    "Bash(npm remove:*)"
    "Bash(psql:*)"
    "Bash(mysql:*)"
    "Bash(mongod:*)"
    "Bash(redis-cli:*)"
    "Bash(pip:*)"
    "Bash(docker rm:*)"
    "Bash(docker rmi:*)"
    "mcp__supabase__execute_sql"
-}}
{{- $managedEnv := dict
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS" "1"
-}}
{{- $currentPerms := default (dict) (get $current "permissions") -}}
{{- $currentEnv := default (dict) (get $current "env") -}}
{{- $merged := merge $managed $current -}}
{{- $_ := set $merged "permissions" (dict
    "allow" (concat $managedAllow (default (list) (get $currentPerms "allow")) | uniq)
    "ask"   (concat $managedAsk   (default (list) (get $currentPerms "ask"))   | uniq)
    "deny"  (concat $managedDeny  (default (list) (get $currentPerms "deny"))  | uniq)
) -}}
{{- $_ := set $merged "env" (merge $managedEnv $currentEnv) -}}
{{- $merged | toPrettyJson -}}
