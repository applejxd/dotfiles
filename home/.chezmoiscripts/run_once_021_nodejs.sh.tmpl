#!/usr/bin/env bash
set -euo pipefail

# 依存
command -v curl >/dev/null 2>&1 || { sudo apt-get update -y && sudo apt-get install -y curl ca-certificates; }

# nvm 導入（未導入時のみ）
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] || curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash

# nvm を読み込み→LTS導入/更新→LTSを有効化（PATH反映）
set +u
. "$NVM_DIR/nvm.sh"
set -u
if [ "$(nvm current 2>/dev/null || true)" != "none" ]; then
  nvm install --lts --reinstall-packages-from=current >/dev/null
else
  nvm install --lts >/dev/null
fi
nvm alias default 'lts/*' >/dev/null
nvm use --silent default

# 確認
echo "Node.js: $(node -v)"
echo "npm: $(npm -v)"
echo "nvm current: $(nvm current)"

{{- if eq .chezmoi.username "applejxd" }}
# AI ツール
npm install -g @anthropic-ai/claude-code
npm install -g @google/gemini-cli
npm install -g @openai/codex
{{- endif }}
